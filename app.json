{
  "expo": {
    "name": "SnapSellr",
    "description": "An app that easily identifies, values, and lists items online.",
    "slug": "SnapSellr",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/SnapSellr_icon.png",
    "scheme": "snapsellr",
    "userInterfaceStyle": "automatic",
    "extra": {
      "API_URL": "http://localhost",
      "API_PORT": "3001",
      "router": {},
      "eas": {
        "projectId": "7728ba8d-8e98-4368-9d2f-66a317f8a711"
      }
    },
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "usesBroadcastPushNotifications": false,
      "newArchEnabled": true,
      "infoPlist": {
        "NSCameraUsageDescription": "SnapSellr uses your camera to scan items for inventory management and point of sale.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "bundleIdentifier": "com.anonymous.snapsellr"
    },
    "android": {
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "versionCode": 1,
      "permissions": [
        "android.permission.CAMERA"
      ],
      "newArchEnabled": true,
      "package": "com.anonymous.snapsellr"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/SnapSellr_icon.png",
      "lang": "en-US"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/SnapSellr_icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
